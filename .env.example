# ─── CORS ──────────────────────────────────────────────────────────────────
# Your frontend's production URL. REQUIRED in production.
FRONTEND_URL=https://artisan-woodfire-vite.vercel.app

# ─── API Authentication ────────────────────────────────────────────────────
# Secret key the frontend sends as X-API-Key on every request.
# Generate with: openssl rand -hex 32
# Set the same value as VITE_API_KEY in the frontend .env
API_SECRET_KEY=replace_with_strong_random_secret

# ─── Staff Portal Password ─────────────────────────────────────────────────
# Password for the Competency page staff login.
STAFF_PORTAL_PASSWORD=woodfire

# ─── Shift4 / HarborTouch POS ──────────────────────────────────────────────
# Your live API key from https://dev.shift4.com → API Keys
SHIFT4_API_KEY=your_shift4_api_key_here

# Webhook signing secret from https://dev.shift4.com → Webhooks
# Used to verify HMAC-SHA256 signatures on incoming webhook events
SHIFT4_WEBHOOK_SECRET=your_webhook_signing_secret

# ─── Sling Scheduling ──────────────────────────────────────────────────────
# API token from https://app.getsling.com → Account → API
SLING_API_TOKEN=your_sling_api_token

# Your Sling organization ID (visible in the URL after login)
SLING_ORG_ID=your_org_id

# The Sling group/channel ID to send kitchen alerts to
SLING_GROUP_ID=your_group_id

# ─── Vercel KV (Persistent Storage) ────────────────────────────────────────
# Create a KV store: vercel kv create artisan-kv
# Then run: vercel env pull  (auto-populates these)
KV_REST_API_URL=https://xxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token
